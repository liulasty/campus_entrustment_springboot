# === App ===
APP_NAME=campus_entrustment
APP_VERSION=1.0.0

# === Backend ===
SPRING_PROFILES_ACTIVE=dev
BACKEND_PORT=8080
JAVA_OPTS=-Xmx512m -Xms256m

# === Database (Host) ===
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=campus_entrustment
DB_USER=root
DB_PASSWORD=

# === Redis (Host) ===
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# === Image Registry ===
REGISTRY=
IMAGE_TAG=latest
